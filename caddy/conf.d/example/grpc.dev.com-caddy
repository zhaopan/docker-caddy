# gRPC Site Configuration
http://grpc.dev.com {
	#tls internal
	#tls grpc@xxabb.xyz

	root * /var/www/html/grpc.dev.com

	reverse_proxy grpc:80

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
	}

	log {
		output file /logs/grpc.dev.com.log {
			roll_size 10mb
			roll_keep 10
			roll_keep_for 720h
		}
		format json {
			time_format "iso8601"
		}
		level INFO
	}
}
