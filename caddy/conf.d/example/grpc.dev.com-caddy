# gRPC Site Configuration
{$GRPC_HOST} {
	#tls internal
	#tls {$GRPC_HOST}

	root * /var/www/html/{$GRPC_HOST}

	reverse_proxy grpc:80

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
	}

	log {
		output file /logs/{$GRPC_HOST}.log {
			roll_size 10mb
			roll_keep 10
			roll_keep_for 720h
		}
		format json {
			time_format "iso8601"
		}
		level INFO
	}
}
