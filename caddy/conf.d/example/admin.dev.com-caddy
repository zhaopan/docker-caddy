# Admin Site Configuration
{$ADMIN_HOST} {
	#tls internal
	#tls {$ADMIN_HOST}

	root * /var/www/html/{$ADMIN_HOST}

	try_files {path} {path}/ /index.html

	file_server

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Cache control for admin static assets
	@static {
		path *.css *.js *.png *.jpg *.jpeg *.gif *.svg *.ico
	}
	header @static Cache-Control "public, max-age=3600"

	# No cache for admin pages
	@admin_pages {
		path /admin/*
	}
	header @admin_pages Cache-Control "no-cache, no-store, must-revalidate"

	encode gzip

	log {
		output file /logs/{$ADMIN_HOST}.log {
			roll_size 10mb
			roll_keep 10
			roll_keep_for 720h
		}
		format json {
			time_format "iso8601"
		}
		level INFO
	}
}
